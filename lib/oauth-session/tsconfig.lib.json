{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc/oauth-session",
    "tsBuildInfoFile": "../../dist/out-tsc/oauth-session.tsbuildinfo",
    "declaration": true,
    "composite": true,
    "disableSourceOfProjectReferenceRedirect": true,
    "lib": ["es2022", "dom"],
    "types": ["node"]
  },
  "references": [
    {
      "path": "../pkce-identity/tsconfig.lib.json"
    }
  ],
  "include": ["src/**/*.ts"],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ]
}
