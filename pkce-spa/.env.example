# Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origins: http://localhost:4201
# Authorized redirect URIs: http://localhost:4201/signin-callback
VITE_OIDC_CLIENT_ID=your-id.apps.googleusercontent.com
# If token exchange fails with "client_secret is missing", add the Web client's
# secret from the same credentials screen (still treat the SPA as public: PKCE is
# the real protection; the secret is often required by Google for "Web" clients).
# VITE_OIDC_CLIENT_SECRET=your-client-secret
