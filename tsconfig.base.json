{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"],
    "paths": {
      "@org/ui": ["lib/ui/src/index.ts"],
      "@org/pkce-identity": ["lib/pkce-identity/src/index.ts"],
      "@org/oauth-session": ["lib/oauth-session/src/index.ts"],
      "mf_remote/Module": ["app/mf_remote/src/remote-entry.ts"]
    }
  }
}
